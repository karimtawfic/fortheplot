rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function roomData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function isRoomHost(roomId) {
      return isAuthenticated() && roomData(roomId).hostPlayerId == request.auth.uid;
    }

    function isPlayerInRoom(roomId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    function roomStatus(roomId) {
      return roomData(roomId).status;
    }

    function isRoomLive(roomId) {
      return roomStatus(roomId) == 'live';
    }

    function isRoomLobby(roomId) {
      return roomStatus(roomId) == 'lobby';
    }

    function playerCount(roomId) {
      return roomData(roomId).currentPlayerCount;
    }

    // ─── Dares ───────────────────────────────────────────────────────────────

    match /dares/{dareId} {
      allow read: if isAuthenticated();
      allow write: if false; // admin SDK / Cloud Functions only
    }

    // ─── Rooms ───────────────────────────────────────────────────────────────

    match /rooms/{roomId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.hostPlayerId == request.auth.uid
        && request.resource.data.status == 'lobby'
        && request.resource.data.currentPlayerCount == 0;

      // Host may update certain fields; full status transitions go through Functions
      allow update: if isAuthenticated()
        && (
          isRoomHost(roomId)
          || (
            // Players may only update lastSeenAt-style fields — all point/status
            // transitions go through Cloud Functions (admin SDK bypasses rules)
            isPlayerInRoom(roomId)
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['currentPlayerCount', 'personalReelsReadyCount'])
          )
        );

      allow delete: if false;

      // ─── Players sub-collection ────────────────────────────────────────────

      match /players/{playerId} {
        allow read: if isAuthenticated() && isPlayerInRoom(roomId);

        allow create: if isAuthenticated()
          && isOwner(playerId)
          && isRoomLobby(roomId)
          && playerCount(roomId) < 20;

        // Players may only update their own non-score fields
        allow update: if isAuthenticated()
          && isOwner(playerId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalPoints', 'isHost', 'roomId']);

        allow delete: if false;
      }

      // ─── Submissions sub-collection ────────────────────────────────────────

      match /submissions/{submissionId} {
        allow read: if isAuthenticated() && isPlayerInRoom(roomId);

        // Submissions are written ONLY through the submitDare Cloud Function
        // (admin SDK). Direct client writes are blocked.
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── Reel Jobs ────────────────────────────────────────────────────────────

    match /reelJobs/{jobId} {
      // Players can read their own jobs; hosts can read group jobs for their room
      allow read: if isAuthenticated()
        && (
          resource.data.playerId == request.auth.uid
          || isRoomHost(resource.data.roomId)
        );

      // All writes go through Cloud Functions / render worker (admin SDK)
      allow write: if false;
    }
  }
}
